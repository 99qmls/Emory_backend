# ======================== 应用基础 ========================
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=true
FRONTEND_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiI1YzIyYzkxZS0wZjAyLTQ2ZTEtYTgxYy0xNzQyODgzMTg0YzYiLCJleHAiOjE3Nzg4MTY5NzV9.ggJ0oKQ48BPtBoNUeB8B94r5QJ8VTR7KE-5eYQqlfZM

# ======================== 数据库 ========================
# PostgreSQL 异步连接 (asyncpg)
DATABASE_URL=postgresql+asyncpg://emory:emory123@localhost:5432/emory_db

# ======================== Redis ========================
REDIS_URL=redis://localhost:6379/0

# ======================== MinIO 对象存储 ========================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=emory-documents

# ======================== JWT 认证 ========================
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# ======================== 大语言模型 (LLM) ========================
# 默认使用的模型，格式：提供商前缀:模型名
# 例如：ollama:deepseek-r1:7b  或  openai:gpt-4o
DEFAULT_LLM_MODEL=ollama:deepseek-r1:7b

# --- 本地 Ollama 配置 ---
OLLAMA_HOST=http://localhost:11434

# --- 云端 OpenAI 兼容 API 配置 (用于 DeepSeek, 智谱, 通义千问 等) ---
OPENAI_API_KEY=sk-a01991201e0b4ebfb8abc175f5856d47
OPENAI_BASE_URL=https://api.deepseek.com/v1   # 按需改为智谱/阿里/OpenAI 地址

# ======================== 向量数据库 (Chroma) ========================
CHROMA_PERSIST_DIR=./chroma_data

# ======================== 嵌入模型 ========================
# 默认嵌入模型名称 (如 "m3e", "text2vec-large-chinese" 等)
EMBEDDING_MODEL_NAME=m3e

# ======================== 重排序模型 (可选) ========================
# 是否启用重排序 (若显存不足可设为 false)
USE_RERANK=true
# 重排序模型名称
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3

# ======================== 情感分析 ========================
# 情感分析使用的模型 (暂用 LLM，未来可切换专用模型)
EMOTION_ANALYZER_MODEL=ollama:deepseek-r1:7b

# ======================== 外部工具集成 ========================
# 高德地图 Web服务 API Key
GAODE_MAPS_API_KEY=	2229e752ea5f5100780d0e2c23123a94
GAODE_MAPS_URL= https://restapi.amap.com/v3/weather/weatherInfo

MCP_WEATHER_URL=http://127.0.0.1:7001/sse

# ======================== 其他 ========================
# Celery 并发数 (可选)
CELERY_WORKER_CONCURRENCY=4